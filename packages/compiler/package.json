{
	"name": "@atomicsmash/compiler",
	"type": "module",
	"version": "3.0.2-beta.2",
	"description": "A universal compiler for all Atomic Smash projects.",
	"keywords": [
		"cli",
		"compiler",
		"webpack"
	],
	"homepage": "https://www.atomicsmash.co.uk/",
	"license": "GPL-3.0-or-later",
	"author": {
		"name": "Atomic Smash",
		"email": "npm@atomicsmash.co.uk",
		"url": "https://www.atomicsmash.co.uk/"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/AtomicSmash/packages",
		"directory": "packages/compiler"
	},
	"files": [
		"./dist/**/*"
	],
	"exports": {
		".": "./dist/index.js"
	},
	"bin": {
		"smash-compile": "./dist/cli.js"
	},
	"types": "index",
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"dev": "tsc --build --watch tsconfig.build.json",
		"build": "npm-run-all clean compile",
		"clean": "del-cli ./dist/ *.tsbuildinfo",
		"compile": "tsc --build tsconfig.build.json",
		"test": "TZ=\"Europe/Istanbul\" vitest run",
		"test:ui": "TZ=\"Europe/Istanbul\" vitest --ui",
		"test:coverage": "TZ=\"Europe/Istanbul\" vitest run --coverage",
		"lint": "run-p lint:*",
		"lint:eslint": "eslint --cache --cache-location ./node_modules/.cache/eslint . --ext .js,.ts,.jsx,.tsx",
		"lint:types": "tsc"
	},
	"dependencies": {
		"@atomicsmash/date-php": "^2.2.0-beta.0",
		"@atomicsmash/smash-config": "^1.0.2-beta.1",
		"@wordpress/dependency-extraction-webpack-plugin": "^6.41.0",
		"browserslist-to-esbuild": "^2.1.1",
		"copy-webpack-plugin": "^14.0.0",
		"cssnano": "^7.1.3",
		"esbuild-loader": "^4.4.2",
		"fast-glob": "^3.3.3",
		"json-loader": "^0.5.7",
		"json2php": "^0.0.12",
		"postcss": "^8.5.8",
		"postcss-loader": "^8.2.1",
		"postcss-preset-env": "^11.2.0",
		"sass": "^1.98.0",
		"sass-loader": "^16.0.7",
		"svg-spritemap-webpack-plugin": "^5.1.0",
		"tsconfig-paths-webpack-plugin": "^4.2.0",
		"tsx": "^4.21.0",
		"webpack": "^5.105.4",
		"webpack-assets-manifest": "^6.5.1",
		"webpack-bundle-analyzer": "^5.2.0",
		"yargs": "^18.0.0"
	},
	"devDependencies": {
		"@tailwindcss/postcss": "^4.2.1",
		"@types/webpack": "^5.28.5",
		"@types/webpack-assets-manifest": "^5.1.4",
		"@types/webpack-bundle-analyzer": "^4.7.0",
		"@types/yargs": "^17.0.35",
		"tailwindcss": "^4.0.9",
		"vue-loader": "^17.4.2"
	},
	"engines": {
		"node": "^20 || >=22"
	}
}
